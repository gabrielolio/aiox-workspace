# ============================================
# AIOX Workspace — .gitignore
# Estratégia: ignorar TUDO, incluir só o que é AIOX
# ============================================

# Ignorar tudo na raiz
/*

# ─── Incluir arquivos e pastas AIOX ───
!.gitignore
!CLAUDE.md
!README.md
!package.json
!package-lock.json
!eslint.config.js
!tsconfig.json
!vitest.config.ts
!.env.example
!.claude/
!.synapse/
!.aios/
!.codex/
!.cursor/
!.gemini/
!.antigravity/
!.github/
!knowledge-base/
!materiais/
!memory/
!docs/
!.ai/
!squads/
!src/
!projects/
!presentations/
!scripts/
!outputs/

# ─── Excluir dentro das pastas incluídas ───

# .claude — settings.local tem caminhos/permissões específicos da máquina
.claude/settings.local.json

# .aios — arquivos grandes e backups
.aios/drive-downloads/
.aios/backup/
.aios/tmp/

# .synapse — sessões e métricas são locais/voláteis
.synapse/sessions/
.synapse/metrics/

# node_modules — nunca no git
node_modules/

# Build outputs
dist/
build/

# Variáveis de ambiente — nunca no git
.env
.env.*
.env.local
.env.*.local
!.env.example

# Framework (já está no npm e no github da Synkra)
.aios-core/

# Dependencies
node_modules/

# Build & Logs
dist/
build/
*.log
logs/

# IDE & OS
.DS_Store
Thumbs.db
.idea/
*.swp
*.key
*.pem

# AIOS Local
.aios/install-log.txt
