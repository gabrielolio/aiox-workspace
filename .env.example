# ============================================
# KING — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# Core IA (Gemini Flash — unico LLM do sistema)
# --------------------------------------------

# Google Gemini API Key
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --------------------------------------------
# Groq (Whisper transcription — squad intel)
# --------------------------------------------

# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=

# --------------------------------------------
# WhatsApp (Evolution API)
# --------------------------------------------

EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
WHATSAPP_INSTANCE=king-bot

# --------------------------------------------
# Database
# --------------------------------------------

# SQLite for MVP
DATABASE_URL=./data/king.db

# --------------------------------------------
# Google Drive (Organizador)
# --------------------------------------------

GOOGLE_CREDENTIALS_PATH=./credentials/google-service-account.json
GOOGLE_DRIVE_FOLDER_ID=

# --------------------------------------------
# Application
# --------------------------------------------

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Vitor's WhatsApp number (for Briefer messages)
VITOR_WHATSAPP=

# Briefer scheduled time (cron: seg 8h)
BRIEFER_CRON=0 8 * * 1
