# ============================================
# KING — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# Core IA
# --------------------------------------------

# Anthropic API (Claude — cerebro dos agentes)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API (Whisper — transcricao de audio)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepSeek API (for AIOS claude-free command)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# --------------------------------------------
# WhatsApp (Evolution API)
# --------------------------------------------

# Evolution API instance URL
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=

# WhatsApp instance name
WHATSAPP_INSTANCE=king-bot

# --------------------------------------------
# Google Drive (Organizador)
# --------------------------------------------

# Google Service Account credentials file path
GOOGLE_CREDENTIALS_PATH=./credentials/google-service-account.json
GOOGLE_DRIVE_FOLDER_ID=

# --------------------------------------------
# Database
# --------------------------------------------

# SQLite for MVP (path to database file)
DATABASE_URL=./data/king.db

# PostgreSQL for production (uncomment when scaling)
# DATABASE_URL=postgresql://user:password@localhost:5432/king

# --------------------------------------------
# Redis (BullMQ — fila de processamento de video)
# --------------------------------------------

REDIS_URL=redis://localhost:6379

# --------------------------------------------
# Application
# --------------------------------------------

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Briefer scheduled time (cron format: seg 8h)
BRIEFER_CRON=0 8 * * 1

# --------------------------------------------
# AIOS Framework
# --------------------------------------------

AIOS_VERSION=4.4.6

# --------------------------------------------
# Deploy (when ready)
# --------------------------------------------

# RAILWAY_TOKEN=
# SENTRY_DSN=
# GITHUB_TOKEN=
